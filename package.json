{
  "name": "ltth-electron",
  "version": "1.3.3",
  "description": "PupCid's Little TikTool Helper - Electron Desktop App",
  "main": "dist/main/main.js",
  "author": {
    "name": "PupCid",
    "email": "pupcid@ltth.app"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "cd source/backend && npm run start",
    "start:electron": "electron .",
    "dev": "node -e \"delete process.env.ELECTRON_RUN_AS_NODE; require('child_process').spawnSync('node_modules/electron/dist/electron.exe', ['.'], {stdio: 'inherit', env: process.env})\"",
    "dev:ts": "NODE_ENV=development npx ts-node source/main/main.ts",
    "dev:backend": "cd source/backend && npm run dev",
    "build": "npm run build:ts && npm run build:css && npm run build:electron",
    "build:ts": "tsc && cd source/backend && npm run build:ts",
    "build:css": "cd source/backend && npm run build:css",
    "build:electron": "electron-builder --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "build:all": "electron-builder -mwl --publish never",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --publish never",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "@electron/rebuild -f -w better-sqlite3",
    "clean": "rimraf dist",
    "test": "cd source/backend && npm test",
    "test:electron": "playwright test electron/test/",
    "lint": "eslint electron/ --ext .js"
  },
  "dependencies": {
    "@eulerstream/euler-websocket-sdk": "^0.0.6",
    "@msgpack/msgpack": "^3.0.0",
    "archiver": "^7.0.1",
    "auto-launch": "^5.0.6",
    "axios": "^1.13.5",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.10.0",
    "bootstrap": "^5.1.3",
    "cheerio": "^1.1.2",
    "chess.js": "^1.4.0",
    "compression": "^1.8.1",
    "dotenv": "^17.2.3",
    "electron-log": "^5.2.0",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.0",
    "express": "^4.22.1",
    "express-rate-limit": "^8.2.1",
    "franc-min": "^6.2.0",
    "gsap": "^3.13.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lowdb": "^7.0.1",
    "marked": "^17.0.0",
    "matter-js": "^0.20.0",
    "multer": "^2.0.2",
    "nanoid": "^5.1.6",
    "obs-websocket-js": "^5.0.6",
    "open": "^10.0.3",
    "openai": "^6.9.1",
    "osc": "^2.4.5",
    "socket.io": "^4.6.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "systeminformation": "^5.31.0",
    "uuid": "^13.0.0",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.18.3",
    "yaml": "^2.8.2",
    "zip-lib": "^1.1.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@electron/notarize": "^2.5.0",
    "@electron/rebuild": "^3.7.0",
    "@playwright/test": "^1.59.1",
    "@types/compression": "^1.8.1",
    "@types/electron": "^1.4.38",
    "@types/express": "^4.17.17",
    "@types/express-serve-static-core": "^4.17.39",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.2",
    "@webgpu/types": "^0.1.69",
    "autoprefixer": "^10.4.22",
    "babel-jest": "^30.2.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.0",
    "eslint": "^9.16.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "p-queue": "^8.1.1",
    "postcss": "^8.5.6",
    "rimraf": "^6.0.1",
    "socket.io-client": "^4.8.1",
    "tailwindcss": "^3.4.18",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "optionalDependencies": {
    "escpos": "^3.0.0-alpha.6",
    "escpos-network": "^3.0.0-alpha.1",
    "escpos-usb": "^3.0.0-alpha.4",
    "playwright": "^1.59.1",
    "puppeteer": "^24.30.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "usb": "^2.14.0",
    "youtube-dl-exec": "^3.1.4"
  },
  "overrides": {
    "glob": "^13.0.1",
    "rimraf": "^6.0.1",
    "inflight": "npm:@whizzzkid/inflight@^2.0.0",
    "lodash.get": "npm:lodash@^4.17.21",
    "lodash.isequal": "npm:lodash@^4.17.21"
  },
  "engines": {
    "node": ">=18.0.0 <25.0.0"
  },
  "build": {
    "extends": "electron/electron-builder.yml"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Loggableim/ltth_dev.git"
  },
  "keywords": [
    "tiktok",
    "streaming",
    "obs",
    "overlay",
    "electron",
    "desktop"
  ]
}
